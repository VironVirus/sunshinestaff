rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function hasUserDoc() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isApprovedActive() {
      return hasUserDoc() &&
        userData().approvalStatus == "approved" &&
        userData().employmentStatus == "active";
    }

    function isSuperAdmin() {
      return isApprovedActive() && userData().isSuperAdmin == true;
    }

    function isLead() {
      return isApprovedActive() &&
        (userData().jobLevel == "manager" || userData().jobLevel == "supervisor");
    }

    function belongsTo(departmentId) {
      return isApprovedActive() && userData().departmentKey == departmentId;
    }

    function isFrontOfficeManager() {
      return belongsTo("front_office") && isLead();
    }

    function isHousekeepingManager() {
      return belongsTo("housekeeping") && isLead();
    }

    function isMaintenanceManager() {
      return belongsTo("maintainance") && isLead();
    }

    function isHumanResourceManager() {
      return belongsTo("human_resource") && isLead();
    }

    function isAuditManager() {
      return belongsTo("audit") && isLead();
    }

    function isNightDutyManager() {
      return belongsTo("night_duty") && isLead();
    }

    function isStoreLead() {
      return belongsTo("store") && isLead();
    }

    function optionalListWithin(data, key, maximum) {
      return !data.keys().hasAny([key]) || (data[key] is list && data[key].size() <= maximum);
    }

    function validSelfRegistration(userId) {
      return signedIn() && request.auth.uid == userId &&
        request.resource.data.uid == userId &&
        request.resource.data.fullName is string && request.resource.data.fullName.size() > 0 &&
        request.resource.data.fullName.size() <= 80 &&
        request.resource.data.email is string && request.resource.data.email.size() <= 254 &&
        request.resource.data.departmentKey is string && request.resource.data.departmentKey.size() <= 40 &&
        request.resource.data.departmentName is string && request.resource.data.departmentName.size() <= 80 &&
        request.resource.data.jobLevel in ["manager", "supervisor", "line_staff"] &&
        request.resource.data.staffTitle is string && request.resource.data.staffTitle.size() <= 80 &&
        request.resource.data.isSuperAdmin == false &&
        request.resource.data.approvalStatus == "pending" &&
        request.resource.data.approvedAt == "" &&
        request.resource.data.approvedByName == "" &&
        request.resource.data.employmentStatus == "active" &&
        request.resource.data.accessLevel in ["department_manager", "department_supervisor", "line_staff"] &&
        optionalListWithin(request.resource.data, "privileges", 40) &&
        optionalListWithin(request.resource.data, "leaveRecords", 120);
    }

    function selfProfileCanUpdate(userId) {
      return signedIn() && request.auth.uid == userId &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "fullName", "birthday", "phoneNumber", "homeAddress", "updatedAt"
        ]) &&
        request.resource.data.fullName is string && request.resource.data.fullName.size() <= 80 &&
        request.resource.data.phoneNumber is string && request.resource.data.phoneNumber.size() <= 30 &&
        request.resource.data.homeAddress is string && request.resource.data.homeAddress.size() <= 250;
    }

    function hrCanUpdateUser(userId) {
      return isHumanResourceManager() && request.auth.uid != userId &&
        resource.data.isSuperAdmin != true &&
        request.resource.data.isSuperAdmin == false &&
        request.resource.data.accessLevel != "super_admin" &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "fullName", "birthday", "phoneNumber", "homeAddress", "departmentKey",
          "departmentName", "jobLevel", "staffTitle", "surcharges", "employmentStatus",
          "approvalStatus", "approvedAt", "approvedByName", "employmentStartDate",
          "sackedAt", "sackedByName", "accessLevel", "privileges", "leaveRecords",
          "monthlySalary", "payrollMonthKey", "absenceDays", "lateCount", "pensionAmount",
          "taxAmount", "salaryUpdatedAt", "salaryUpdatedByName", "lastProfileNotification",
          "lastProfileNotificationAt", "updatedAt"
        ]) && optionalListWithin(request.resource.data, "privileges", 40) &&
        optionalListWithin(request.resource.data, "leaveRecords", 120);
    }

    function housekeepingCanUpdateFrontOffice() {
      return isHousekeepingManager() &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "cleanedRoomNumbers", "cleanedRooms", "otherCleanedAreas", "reportHistory",
          "housekeepingUpdatedAt", "housekeepingUpdatedByUid", "housekeepingUpdatedByName",
          "housekeepingUpdatedByDepartment"
        ]);
    }

    function housekeepingCanCreateFrontOffice() {
      return isHousekeepingManager() && request.resource.data.keys().hasOnly([
        "cleanedRoomNumbers", "cleanedRooms", "otherCleanedAreas", "reportHistory",
        "housekeepingUpdatedAt", "housekeepingUpdatedByUid", "housekeepingUpdatedByName",
        "housekeepingUpdatedByDepartment"
      ]);
    }

    function validFrontOfficeSize() {
      return optionalListWithin(request.resource.data, "occupiedRooms", 88) &&
        optionalListWithin(request.resource.data, "occupiedRoomNumbers", 88) &&
        optionalListWithin(request.resource.data, "cleanedRoomNumbers", 88) &&
        optionalListWithin(request.resource.data, "otherCleanedAreas", 40) &&
        optionalListWithin(request.resource.data, "roomMoves", 500) &&
        optionalListWithin(request.resource.data, "reportHistory", 120) &&
        optionalListWithin(request.resource.data, "activityEntries", 300);
    }

    function housekeepingCanUpdateMaintenance() {
      return isHousekeepingManager() &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "roomIssues", "roomIssuesUpdatedAt", "roomIssuesUpdatedByUid",
          "roomIssuesUpdatedByName", "roomIssuesUpdatedByDepartment"
        ]);
    }

    function housekeepingCanCreateMaintenance() {
      return isHousekeepingManager() && request.resource.data.keys().hasOnly([
        "roomIssues", "roomIssuesUpdatedAt", "roomIssuesUpdatedByUid",
        "roomIssuesUpdatedByName", "roomIssuesUpdatedByDepartment"
      ]);
    }

    function nightDutyCanUpdateUtilities() {
      return isNightDutyManager() &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "utilities", "utilitiesUpdatedAt", "utilitiesUpdatedByUid",
          "utilitiesUpdatedByName", "utilitiesUpdatedByDepartment"
        ]);
    }

    function nightDutyCanCreateUtilities() {
      return isNightDutyManager() && request.resource.data.keys().hasOnly([
        "utilities", "utilitiesUpdatedAt", "utilitiesUpdatedByUid",
        "utilitiesUpdatedByName", "utilitiesUpdatedByDepartment"
      ]);
    }

    function complaintLead() {
      return isFrontOfficeManager() || isHousekeepingManager() || isMaintenanceManager();
    }

    function complaintLeadCanUpdate() {
      return complaintLead() &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "roomComplaints", "roomComplaintsUpdatedAt", "roomComplaintsUpdatedByUid",
          "roomComplaintsUpdatedByName", "roomComplaintsUpdatedByDepartment"
        ]);
    }

    function complaintLeadCanCreate() {
      return complaintLead() && request.resource.data.keys().hasOnly([
        "roomComplaints", "roomComplaintsUpdatedAt", "roomComplaintsUpdatedByUid",
        "roomComplaintsUpdatedByName", "roomComplaintsUpdatedByDepartment"
      ]);
    }

    function validMaintenanceSize() {
      return optionalListWithin(request.resource.data, "roomIssues", 88) &&
        optionalListWithin(request.resource.data, "roomComplaints", 300);
    }

    function validRoomPropertyStatusReport() {
      return request.resource.data.keys().hasOnly([
          "roomNumber", "floorKey", "floorLabel", "inspectionDate", "items",
          "otherDamages", "updatedAt", "updatedAtIso", "updatedByUid",
          "updatedByName", "updatedByDepartment"
        ]) &&
        request.resource.data.roomNumber is string &&
        request.resource.data.roomNumber.size() > 0 &&
        request.resource.data.roomNumber.size() <= 20 &&
        request.resource.data.floorKey is string &&
        request.resource.data.floorKey.size() <= 40 &&
        request.resource.data.floorLabel is string &&
        request.resource.data.floorLabel.size() <= 80 &&
        request.resource.data.inspectionDate is string &&
        request.resource.data.inspectionDate.size() == 10 &&
        request.resource.data.items is list &&
        request.resource.data.items.size() == 53 &&
        request.resource.data.otherDamages is string &&
        request.resource.data.otherDamages.size() <= 2000 &&
        request.resource.data.updatedAt is timestamp &&
        request.resource.data.updatedAtIso is string &&
        request.resource.data.updatedAtIso.size() <= 40 &&
        request.resource.data.updatedByUid == request.auth.uid &&
        request.resource.data.updatedByName == userData().fullName &&
        request.resource.data.updatedByDepartment == userData().departmentName;
    }

    function canWriteTrackedEntries() {
      return isSuperAdmin() || isLead() || belongsTo("store");
    }

    function validTrackedEntry() {
      return request.resource.data.actorUid == request.auth.uid &&
        request.resource.data.actorName == userData().fullName &&
        request.resource.data.actorDepartment == userData().departmentName &&
        request.resource.data.actorDepartmentKey == userData().departmentKey &&
        request.resource.data.createdAt is string && request.resource.data.createdAt.size() <= 40 &&
        request.resource.data.message is string && request.resource.data.message.size() <= 500;
    }

    function canReadNotification() {
      return isApprovedActive() && (
        resource.data.audienceTag == "all" ||
        (resource.data.audienceTag == "operations" && (isSuperAdmin() || isFrontOfficeManager() || isHousekeepingManager() || (belongsTo("food_beverages") && isLead()) || (belongsTo("night_duty") && isLead()))) ||
        (resource.data.audienceTag == "events" && (isSuperAdmin() || isLead())) ||
        (resource.data.audienceTag == "housekeeping_reports" && (isSuperAdmin() || isHousekeepingManager())) ||
        (resource.data.audienceTag == "property" && (isSuperAdmin() || isLead())) ||
        (resource.data.audienceTag == "store" && (isSuperAdmin() || belongsTo("store"))) ||
        (resource.data.audienceTag == "night-duty" && (isSuperAdmin() || isNightDutyManager()))
      );
    }

    match /users/{userId} {
      allow create: if validSelfRegistration(userId);
      allow get: if (signedIn() && request.auth.uid == userId) ||
        (isApprovedActive() && (
          isSuperAdmin() || isHumanResourceManager() || isAuditManager()
        ));
      allow list: if isApprovedActive() && (
        isSuperAdmin() || isHumanResourceManager() || isAuditManager()
      );
      allow update: if isSuperAdmin() || hrCanUpdateUser(userId) || selfProfileCanUpdate(userId);
      allow delete: if isSuperAdmin() && request.auth.uid != userId;
    }

    match /portal/highlights {
      allow read: if isApprovedActive();
      allow write: if isSuperAdmin();
    }

    match /portal/siteContent {
      allow read: if isApprovedActive();
      allow write: if isSuperAdmin() &&
        optionalListWithin(request.resource.data, "announcements", 100) &&
        optionalListWithin(request.resource.data, "newsItems", 100);
    }

    match /portal/frontOffice {
      allow read: if isSuperAdmin() || isFrontOfficeManager() || isHousekeepingManager() ||
        (belongsTo("food_beverages") && isLead()) || (belongsTo("night_duty") && isLead());
      allow create: if validFrontOfficeSize() && (isSuperAdmin() || isFrontOfficeManager() || housekeepingCanCreateFrontOffice());
      allow update: if validFrontOfficeSize() && (isSuperAdmin() || isFrontOfficeManager() || housekeepingCanUpdateFrontOffice());
    }

    match /portal/maintenance {
      allow read: if isSuperAdmin() || isLead();
      allow create: if validMaintenanceSize() && (isSuperAdmin() || isMaintenanceManager() || housekeepingCanCreateMaintenance() || nightDutyCanCreateUtilities() || complaintLeadCanCreate());
      allow update: if validMaintenanceSize() && (isSuperAdmin() || isMaintenanceManager() || housekeepingCanUpdateMaintenance() || nightDutyCanUpdateUtilities() || complaintLeadCanUpdate());
    }

    match /portal/eventsBookings {
      allow read: if isSuperAdmin() || isLead();
      allow write: if optionalListWithin(request.resource.data, "events", 200) && (isSuperAdmin() || isFrontOfficeManager());
    }

    match /portal/housekeepingReports {
      allow read: if isSuperAdmin() || isHousekeepingManager();
      allow write: if optionalListWithin(request.resource.data, "morningRooms", 88) &&
        optionalListWithin(request.resource.data, "afternoonRooms", 88) &&
        (isSuperAdmin() || isHousekeepingManager());
    }

    match /roomPropertyStatus/{reportId} {
      allow read: if isSuperAdmin() || isLead();
      allow create, update: if isHousekeepingManager() &&
        validRoomPropertyStatusReport();
      allow delete: if false;
    }

    match /portal/storeInventory {
      allow read: if isSuperAdmin() || belongsTo("store");
      allow write: if optionalListWithin(request.resource.data, "acquisitions", 400) &&
        optionalListWithin(request.resource.data, "requisitions", 400) &&
        optionalListWithin(request.resource.data, "returns", 400) &&
        optionalListWithin(request.resource.data, "adjustments", 400) &&
        (isSuperAdmin() || isStoreLead());
    }

    match /portal/nightDuty {
      allow read: if isSuperAdmin() || isNightDutyManager();
      allow write: if optionalListWithin(request.resource.data, "onDutyStaff", 200) && (isSuperAdmin() || isNightDutyManager());
    }

    match /notifications/{notificationId} {
      allow read: if canReadNotification();
      allow create: if canWriteTrackedEntries() && validTrackedEntry() &&
        request.resource.data.title is string && request.resource.data.title.size() <= 120 &&
        request.resource.data.audienceTag in ["all", "operations", "events", "housekeeping_reports", "property", "store", "night-duty"];
    }

    match /activityLogs/{logId} {
      allow read: if isSuperAdmin() || isHumanResourceManager() || isAuditManager();
      allow create: if canWriteTrackedEntries() && validTrackedEntry();
    }

    match /departments/{departmentId} {
      allow read: if isSuperAdmin() || isHumanResourceManager() || isAuditManager() || belongsTo(departmentId);
      allow write: if optionalListWithin(request.resource.data, "shifts", 400) &&
        (isSuperAdmin() || (belongsTo(departmentId) && isLead()));
    }
  }
}
